# ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o Git
# ──────────────────────────────────────────────

# Belvo — pegue em: https://dashboard.belvo.com → Settings → API Keys
BELVO_SECRET_ID="sua_secret_id_aqui"
BELVO_SECRET_PASSWORD="sua_secret_password_aqui"
BELVO_ENV=sandbox
# BELVO_ENV=production   ← mude quando for para produção

# Servidor
PORT=3001

# Segurança: URL do seu frontend (sem barra no final)
# Ex: http://localhost:5173 em dev | https://fincento.vercel.app em produção
FRONTEND_URL=http://localhost:5173
