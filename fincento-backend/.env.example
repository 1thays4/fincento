# ──────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA suba o .env para o Git
# ──────────────────────────────────────────────

# Belvo — pegue em: https://dashboard.belvo.com → Settings → API Keys
# (Opcional — o app funciona sem Belvo, apenas com importação OFX/CSV)
BELVO_SECRET_ID="sua_secret_id_aqui"
BELVO_SECRET_PASSWORD="sua_secret_password_aqui"
BELVO_ENV=sandbox

# Servidor
PORT=3001

# Segurança: URL do seu frontend (sem barra no final)
FRONTEND_URL=http://localhost:5173

# Turso (SQLite na nuvem) — crie em: https://turso.tech
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=seu-token-aqui

# Autenticação PIN (4 dígitos)
# Gere o hash com: node -e "console.log(require('crypto').createHash('sha256').update('1234').digest('hex'))"
# Se não definir, o app roda sem autenticação (modo dev)
AUTH_PIN_HASH=
# String aleatória para assinar tokens — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
